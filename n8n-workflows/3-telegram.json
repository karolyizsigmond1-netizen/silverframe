        "end": "={{ $json.endDate }}",
        "additionalFields": {
          "summary": "🚫 Foglalt",
          "status": "confirmed"
        }
      },
      "id": "sf-tg-19",
      "name": "Naptár: nap blokkolás",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1,
      "position": [1780, 640],
      "credentials": { "googleCalendarOAuth2Api": { "id": "1", "name": "Google Calendar OAuth2" } }
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $('AI válasz feldolgozás').first().json.chatId }}",
        "text": "=🚫 Le van zárva: <b>{{ $('Blokkolás előkészítés').first().json.date }}</b>{{ $('Blokkolás előkészítés').first().json.endDate ? ' — ' + $('Blokkolás előkészítés').first().json.date : '' }}",
        "additionalFields": { "parse_mode": "HTML" }
      },
      "id": "sf-tg-20",
      "name": "Telegram: blokk ack",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [2000, 640],
      "credentials": { "telegramApi": { "id": "2", "name": "Telegram Bot" } }
    },

    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $json.chatId }}",
        "text": "Nem értettem az üzenetet. Próbálj valami ilyesmit:\n• \"add: holnap 14:00 fodrász\"\n• \"le van foglalva kedd\"\n• \"hétfőtől szerdáig szabadság\"",
