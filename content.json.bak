  "servicePages": {
    "portfolio-model": {
      "title": "Portfólió / Modell Fotózás — Silverframe Studio | Szeged",
      "metaDesc": "Professzionális portfólió és modell fotózás Szegeden. Start csomag 70.000 Ft, Prémium csomag 95.000 Ft.",
      "ogImage": "uploads/cc282a829b85-Portf_li__-Premium_csomag.jpg",
